# ====================================================================
# Authentication Configuration
# ====================================================================
# The server automatically detects the authentication mode:
# - If SERVICE_KEY_PATH or SERVICE_KEY is provided: Uses XSUAA OAuth 2.0
# - Otherwise: Uses basic authentication (username/password)

# ====================================================================
# Option 1: Basic Authentication (Traditional ABAP Systems)
# ====================================================================
# If no service key is provided, these variables are required
SAP_URL=https://example.sap-server.com:44300
SAP_USER=EXAMPLE_USER
SAP_PASSWORD=your_password_here
SAP_CLIENT=100
SAP_LANGUAGE=EN

# ====================================================================
# Option 2: XSUAA Authentication (SAP BTP ABAP Cloud)
# ====================================================================
# Provide the path to your BTP service key JSON file
# SERVICE_KEY_PATH=./servicekey.json

# For password grant flow (user authentication with XSUAA), provide cloud credentials:
# SAP_CLOUD_USER=your.email@company.com
# SAP_CLOUD_PASSWORD=your_password_here

# Optional: Client and Language
# SAP_CLIENT=
# SAP_LANGUAGE=EN
